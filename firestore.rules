rules_version = '2';
// Deploy: firebase deploy --only firestore:rules (from mens-store/)
// Checkout updates products with { stock } and/or { stock, sizes }. Per-size keys outside
// XS/S/M/L/XL/XXL (any case) are not decremented by rules logic—prefer those keys or admin-only inventory.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin: document users/{uid} must have role == "admin"
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile: read own; create as role "user" with allowed fields only; cannot change role client-side
    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'photoURL', 'role', 'createdAt']);

      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    match /users/{userId}/orders/{orderId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // Per-user wishlist (single doc with an `ids` array). Owner-only.
    match /users/{userId}/wishlist/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public newsletter signups (site banner)
    match /newsletter_subscribers/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 3
        && request.resource.data.email.size() <= 320;
      allow read, update, delete: if isAdmin();
    }

    function orderStatusValue(s) {
      return s in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    // Mirrors allowedNextStatuses() in lib/admin/orders-admin.ts. Keep in sync.
    function isValidStatusTransition(prev, next) {
      return prev == next
        || (prev == 'pending' && (next == 'processing' || next == 'cancelled'))
        || (prev == 'processing' && (next == 'shipped' || next == 'cancelled'))
        || (prev == 'shipped' && (next == 'delivered' || next == 'cancelled'))
        || (prev == 'delivered' && next == 'cancelled');
    }

    // Shipping must be free per business rule; pricing fields must be non-negative numbers
    // and total = subtotal - discount + shipping. Does not validate per-item prices — for
    // that we need server-side (Admin SDK) order placement (planned: Batch 2).
    function validPricing(p) {
      return p is map
        && p.subtotal is number && p.subtotal >= 0
        && p.discount is number && p.discount >= 0
        && p.shipping is number && p.shipping == 0
        && p.total is number && p.total >= 0
        && p.discount <= p.subtotal
        && p.total == p.subtotal - p.discount + p.shipping;
    }

    // Checkout creates orders (guest or signed-in). Reads restricted: signed-in owner or admin.
    // Guests get their order details echoed in the placeOrder response and stashed client-side.
    match /orders/{orderId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.userId is string
        && request.resource.data.orderNumber is string
        && request.resource.data.orderNumber.matches('^[A-Z0-9]{8}$')
        && request.resource.data.items is list
        && request.resource.data.shippingAddress is map
        && validPricing(request.resource.data.pricing)
        && request.resource.data.paymentMethod in ['cod', 'online']
        && (!('shipping' in request.resource.data.keys()) || request.resource.data.shipping is map);

      // Admin can change status / statusHistory / shipping / inventoryRestored. Status moves
      // must follow the allowed transition graph. Order owner can only update the shipping
      // field (used after Shiprocket call completes on the client).
      allow update: if (
          isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'statusHistory', 'shipping', 'inventoryRestored'])
          && orderStatusValue(request.resource.data.status)
          && request.resource.data.statusHistory is list
          && isValidStatusTransition(resource.data.status, request.resource.data.status)
        ) || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shipping'])
          && request.resource.data.shipping is map
        );

      allow delete: if false;
    }

    // Customer-initiated cancellation requests for an order.
    //  - Owner can create one request per order while it's still pending/processing.
    //  - Owner can read their own request; admin can read + update (to mark fulfilled/rejected).
    match /orders/{orderId}/cancellationRequests/{requestId} {
      allow read: if isAdmin()
        || (
          isSignedIn()
          && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid
        );
      allow create: if isSignedIn()
        && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(orderId)).data.status in ['pending', 'processing']
        && request.resource.data.status == 'pending'
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolution', 'resolvedAt', 'resolvedBy'])
        && request.resource.data.status in ['fulfilled', 'rejected', 'pending'];
      allow delete: if false;
    }

    // Whole non-negative quantity: number (incl. float whole) or digit-only string (admin often saves strings).
    function isNonNegWholeNumber(n) {
      return n is number && n >= 0 && n == int(n)
        || n is string && n.matches('^[0-9]{1,12}$');
    }

    // New stock from checkout is always a number; old may be number or numeric string.
    function newStockLteOld(oldV, newV) {
      return newV is number && newV >= 0 && newV == int(newV)
        && (
          (oldV is number && oldV >= 0 && oldV == int(oldV) && newV <= oldV)
          || (oldV is string && oldV.matches('^[0-9]{1,12}$') && newV <= int(oldV))
        );
    }

    // Legacy inventory: `size` is a list whose first entry is a map of size → qty (see getSizesMap in app).
    function legacyFirstSizeEntryIsMap(oldD) {
      return oldD.keys().hasAny(['size'])
        && oldD.size is list
        && oldD.size.size() > 0
        && oldD.size[0] is map;
    }

    // Per-size qty must not increase for known keys (covers XS–XXL upper/lower).
    function mapKeyLte(newS, oldS, k) {
      let hasN = k in newS.keys();
      let hasO = k in oldS.keys();
      return !hasN
        || (hasO
          && isNonNegWholeNumber(newS[k])
          && isNonNegWholeNumber(oldS[k])
          && (
            (newS[k] is number && oldS[k] is number && newS[k] <= oldS[k])
            || (newS[k] is number && oldS[k] is string && oldS[k].matches('^[0-9]{1,12}$') && newS[k] <= int(oldS[k]))
            || (newS[k] is string && newS[k].matches('^[0-9]{1,12}$') && oldS[k] is number && int(newS[k]) <= oldS[k])
            || (newS[k] is string && oldS[k] is string && newS[k].matches('^[0-9]{1,12}$') && oldS[k].matches('^[0-9]{1,12}$') && int(newS[k]) <= int(oldS[k]))
          ))
        || (!hasO
          && isNonNegWholeNumber(newS[k])
          && ((newS[k] is number && newS[k] == 0) || (newS[k] is string && newS[k] == '0')));
    }

    function sizesMapNonIncreasing(newS, oldS) {
      return mapKeyLte(newS, oldS, 'XS')
        && mapKeyLte(newS, oldS, 'S')
        && mapKeyLte(newS, oldS, 'M')
        && mapKeyLte(newS, oldS, 'L')
        && mapKeyLte(newS, oldS, 'XL')
        && mapKeyLte(newS, oldS, 'XXL')
        && mapKeyLte(newS, oldS, 'xs')
        && mapKeyLte(newS, oldS, 's')
        && mapKeyLte(newS, oldS, 'm')
        && mapKeyLte(newS, oldS, 'l')
        && mapKeyLte(newS, oldS, 'xl')
        && mapKeyLte(newS, oldS, 'xxl');
    }

    // Client checkout: aggregate stock down, or per-size map + stock total (no new size keys; known keys only decrease).
    // (No if/else in functions—Firestore rules are expression-only.)
    function clientInventoryDecrement() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      let newD = request.resource.data;
      let oldD = resource.data;

      return (affected.hasOnly(['stock'])
          && oldD.keys().hasAny(['stock'])
          && newStockLteOld(oldD.stock, newD.stock))
        || (affected.hasOnly(['stock', 'sizes'])
          && isNonNegWholeNumber(newD.stock)
          && newD.sizes is map
          && (
            (oldD.sizes is map
              && newD.sizes.keys().hasOnly(oldD.sizes.keys())
              && sizesMapNonIncreasing(newD.sizes, oldD.sizes))
            || (!(oldD.sizes is map)
              && legacyFirstSizeEntryIsMap(oldD)
              && newD.sizes.keys().hasOnly(oldD.size[0].keys())
              && sizesMapNonIncreasing(newD.sizes, oldD.size[0]))
          )
          && (!oldD.keys().hasAny(['stock']) || newStockLteOld(oldD.stock, newD.stock)));
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || clientInventoryDecrement();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

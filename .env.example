# Copy to .env.local and replace with values from Firebase Console → Project settings → Your apps.
# NEXT_PUBLIC_* variables are exposed to the browser; protect data with Firestore/Storage rules + Auth.

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Canonical URL for OG tags, sitemap, robots, and product QR deep links (no trailing slash)
# Example: https://secondskinmensworld.com — printed QRs use this for Scan & stock ?product=…
NEXT_PUBLIC_SITE_URL=https://secondskinmensworld.com

# Shiprocket (server-only — never prefix with NEXT_PUBLIC_)
# Used by /api/shiprocket/create-order to auto-book a shipment when a customer places an order.
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password
# Nickname of the pickup location registered in Shiprocket (Settings → Pickup Addresses)
SHIPROCKET_PICKUP_LOCATION=Primary
# Default package dimensions (cm) and per-item weight (kg) for the adhoc order payload
SHIPROCKET_PACKAGE_LENGTH_CM=25
SHIPROCKET_PACKAGE_BREADTH_CM=20
SHIPROCKET_PACKAGE_HEIGHT_CM=5
SHIPROCKET_PER_ITEM_WEIGHT_KG=0.5
SHIPROCKET_MIN_WEIGHT_KG=0.5
